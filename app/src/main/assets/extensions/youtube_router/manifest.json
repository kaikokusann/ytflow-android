{
  "manifest_version": 2,
  "name": "YouTube Mode Router",
  "version": "0.1.17",
  "description": "Routes YouTube watch/live pages to desktop host and browsing pages to mobile host.",
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-router@local"
    }
  },
  "permissions": [
    "*://www.youtube.com/*",
    "*://m.youtube.com/*",
    "*://youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://m.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": [
        "router.js"
      ],
      "run_at": "document_start"
    }
  ]
}
